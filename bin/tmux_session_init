#!/usr/bin/env bash

# Executed from Tmux hook session-created and window-linked.
# If a file is called .tmux-init in a projet directory, execute it.

SESSION_NAME="$1"
# Session name, only given for window-linked, where $1 is just the window name
# and can't tell us which session it belongs to on its own.
PARENT_SESSION_NAME="${2:-}"

# Build a fully-qualified target -- a bare name can collide with an unrelated
# session/window sharing it.
if [ -n "$PARENT_SESSION_NAME" ]; then
	SESSION_TARGET="$PARENT_SESSION_NAME:$SESSION_NAME"
else
	SESSION_TARGET="$SESSION_NAME:"
fi
# #{pane_current_path} is derived by inspecting the pane's live process, which
# races tmux's own internal update and can still be stale/wrong the instant the
# hook fires. #{pane_start_path} is the -c argument captured directly at pane
# creation, with nothing to race.
SESSION_PROJECT_PATH="$(tmux display-message -t "$SESSION_TARGET" -p '#{pane_start_path}')"
SESSION_PROJECT_SCRIPT=".tmux-init"
SESSION_PROJECT_SCRIPT_PATH="${SESSION_PROJECT_PATH}/${SESSION_PROJECT_SCRIPT}"

# Execute global init script
(exec "$HOME/.dotfiles/custom/tmux_session_init_custom" "$SESSION_NAME" "$SESSION_PROJECT_PATH" "$SESSION_TARGET")

# Execute projet init script
if [ -f "$SESSION_PROJECT_SCRIPT_PATH" ] && [ -x "$SESSION_PROJECT_SCRIPT_PATH" ]; then
	(exec "$SESSION_PROJECT_SCRIPT_PATH")
fi
