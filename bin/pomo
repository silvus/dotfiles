#!/usr/bin/env python3
"""Pomodoro timer"""

import os
import select
import subprocess
import sys
import termios
import time
import tty

# ---------------------------------------------------------------------------
# Splits: (label, work_seconds, rest_seconds)
# ---------------------------------------------------------------------------

SPLITS = [
    ("25/5", 25 * 60, 5 * 60),
    ("25/25", 25 * 60, 25 * 60),
    ("50/10", 50 * 60, 10 * 60),
    # ("5/1", 5 * 60, 1 * 60),
    # ("1/1",    1 * 60,  1 * 60),
]

_LABELS = [s[0] for s in SPLITS] + ["All done"]

BAR_WIDTH = 40

# Tango palette (24-bit ANSI)
_RESET = "\033[0m"
_SKY = "\033[38;2;114;159;207m"  # work
_CHAMELEON = "\033[38;2;78;154;6m"  # break

# ---------------------------------------------------------------------------
# Terminal primitives
# ---------------------------------------------------------------------------


def _w(s):
    sys.stdout.write(s)
    sys.stdout.flush()


def _hide_cursor():
    _w("\033[?25l")


def _show_cursor():
    _w("\033[?25h")


def _up(n):
    if n > 0:
        _w(f"\033[{n}A")


def _read_key():
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)  # disable line buffering: deliver each keypress immediately
        ch = os.read(fd, 1).decode("utf-8", errors="replace")
        if ch == "\x1b":
            # Could be the start of an escape sequence (e.g. arrow keys send
            # "\x1b[A"). Read one byte at a time until the sequence ends
            # (letter or ~) or until no more bytes arrive within 50 ms
            # (bare Escape keypress).
            seq = ch
            while True:
                ready, _, _ = select.select([sys.stdin], [], [], 0.05)
                if not ready:
                    break
                byte = os.read(fd, 1).decode("utf-8", errors="replace")
                seq += byte
                if byte.isalpha() or byte == "~":  # standard ANSI terminator
                    break
            return seq
        return ch
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)  # always restore terminal


# ---------------------------------------------------------------------------
# Widgets
# ---------------------------------------------------------------------------


def _select(title, options, default=0):
    """Arrow-key select menu. Returns chosen index."""
    n = len(options)
    sel = default
    _hide_cursor()
    # Print title, a blank line, then one line per option.
    _w(f"{title}\n\n" + "".join(f"  {opt}\n" for opt in options))
    try:
        while True:
            _up(n)  # jump back up to the first option line
            for i, opt in enumerate(options):
                marker = "\033[1m▶\033[0m " if i == sel else "  "
                _w(f"\r{marker}{opt}\033[K\n")  # redraw line, erase any trailing chars
            key = _read_key()
            if key in ("\r", "\n"):
                break
            elif key == "\x1b[A":  # up arrow
                sel = (sel - 1) % n
            elif key == "\x1b[B":  # down arrow
                sel = (sel + 1) % n
            elif key in ("\x03", "\x04"):  # Ctrl-C / Ctrl-D
                raise KeyboardInterrupt
    finally:
        _show_cursor()
        # Erase the whole menu (title + blank line + N options) and leave
        # the cursor where the title was so the next output starts cleanly.
        total = n + 2
        _up(total)
        for _ in range(total):
            _w("\r\033[K\n")
        _up(total)
    return sel


def _confirm(prompt, default=True):
    return _select(prompt, ["Yes", "No"], default=0 if default else 1) == 0


# ---------------------------------------------------------------------------
# Countdown
# ---------------------------------------------------------------------------


def _bar(pct, color=""):
    # Clamp to BAR_WIDTH to guard against floating-point drift past 1.0.
    filled = min(round(pct * BAR_WIDTH), BAR_WIDTH)
    fill = f"{color}{'█' * filled}{_RESET}" if color else "█" * filled
    return fill + "░" * (BAR_WIDTH - filled)  # ░ = empty portion


def _countdown(label, seconds, color=""):
    _hide_cursor()
    end = time.monotonic() + seconds
    # Precompute colored label padded to 5 chars so Work/Break always align.
    tag = f"{color}{label:<5}{_RESET}"
    try:
        while True:
            remaining = end - time.monotonic()
            if remaining <= 0:
                _w(f"\r{tag} [{_bar(1.0, color)}] 100%\033[K\n")
                return
            pct = (seconds - remaining) / seconds
            m, s = divmod(int(remaining), 60)
            _w(
                f"\r{tag} [{_bar(pct, color)}] {int(pct * 100):3d}%  {m:02d}:{s:02d} remaining\033[K"
            )
            # Sleep until the next whole-second boundary instead of a fixed 1 s,
            # so the display never drifts behind real time.
            time.sleep(remaining % 1 or 1)
    finally:
        _show_cursor()


# ---------------------------------------------------------------------------
# Notification
# ---------------------------------------------------------------------------


def _notify(msg):
    try:
        # Popen (not run) so we don't block the timer waiting for the
        # notification daemon to respond.
        subprocess.Popen(
            ["notify-send", "-a", "Pomodoro", "Pomodoro", msg],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except OSError:
        pass  # notify-send not installed


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------


def _run():
    """Run one pomodoro round. Returns True when the session should end."""
    idx = _select("Choose a pomodoro split.", _LABELS)
    if idx == len(SPLITS):  # user picked the last, so "All done"
        return True

    _, work, rest = SPLITS[idx]

    _countdown("Work", work, _SKY)
    _notify("Work Timer is up! Take a Break 😊")

    if not _confirm("Ready for a break?"):
        return False  # skip break, loop back to the split picker

    _countdown("Break", rest, _CHAMELEON)
    _notify("Break is over! Get back to work 💪")

    return False  # loop back for another round


def main():
    try:
        while not _run():
            pass
    except KeyboardInterrupt:
        _show_cursor()  # make sure cursor is restored if the user quits mid-timer
        print()


if __name__ == "__main__":
    main()
