{
    "colorscheme": "monokai-dark",
    "diffgutter": true,
    "fastdirty": true,
    "indentchar": "\t",
    "matchbrace": false,
    "mkparents": true,
    "pluginchannels": [
        "https://raw.githubusercontent.com/micro-editor/plugin-channel/master/channel.json"
    ],
    "pluginrepos": [],
    "rmtrailingws": true,
    "savecursor": true,
    "saveundo": true,
    "scrollmargin": 15,
    "splitBottom": true,
    "splitRight": true,
    "statusformatl": "$(filename) $(modified)($(line),$(col)) $(status.paste)| ft:$(opt:filetype) | $(opt:fileformat) | $(opt:encoding)",
    "termtitle": false,
    "xterm": true
}
